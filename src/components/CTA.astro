<section class="cta section" id="contact">
  <div class="container">
    <div class="cta-card">
      <h2 class="cta-heading">
        Ready to transform your<br />
        conversations into <span class="text-accent">results</span>?
      </h2>
      <p class="cta-sub">
        Drop us a line and let's explore how Accordia can streamline your business.
      </p>
      <div class="cta-actions">
        <a href="mailto:hello@accordia.ai" class="btn btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22 7 12 13 2 7"/></svg>
          info@accordia.co.za
        </a>
        <a href="tel:+27211234567" class="btn btn-outline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +27 79 732 3744
        </a>
      </div>
      <p class="cta-location">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Cape Town, South Africa
      </p>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.from('.cta-card', {
      autoAlpha: 0,
      y: 50,
      scale: 0.97,
      duration: 0.8,
      ease: 'power2.out',
      scrollTrigger: { trigger: '.cta', start: 'top 75%' },
    });
  });
</script>

<style>
  .cta {
    background: var(--bg-surface);
  }

  .cta-card {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
    border-radius: var(--radius-lg);
    background: var(--bg-elevated);
    border: 1px solid rgba(255, 255, 255, 0.04);
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    translate: -50% 0;
    width: 140%;
    height: 100%;
    background: radial-gradient(ellipse, rgba(190, 255, 0, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta-heading {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    margin-bottom: 0.6em;
    position: relative;
  }

  .cta-sub {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: var(--space-md);
    margin-inline: auto;
    position: relative;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    position: relative;
  }

  .cta-location {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    color: var(--text-muted);
    font-size: 0.9rem;
    position: relative;
  }

  .cta-location svg {
    flex-shrink: 0;
  }
</style>
