---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Accordia AI — Chat becomes business',
  description = 'AI-powered WhatsApp conversations that drive your business forward. 24/7 automation, smart workflows, and real-time insights.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08080D" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&f[]=satoshi@400,500,700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <div class="grain" aria-hidden="true"></div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
